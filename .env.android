# Used by: npm run build:android
# Copy to .env.android.local and set your HR server URL (same network as the phone).

# Same REST API as desktop — point to your PC/server running `npm run server` or Dropsoft HR.
# Emulator → host machine: http://10.0.2.2:PORT
# Physical phone on Wi‑Fi → use your PC's LAN IP (NOT 127.0.0.1 — that is the phone itself):
# VITE_ANDROID_API_URL=http://192.168.1.50:32100
# Android Emulator only → host PC:
VITE_ANDROID_API_URL=http://10.0.2.2:32100

VITE_USE_LOCAL_API=true
VITE_CAPACITOR=true
