# Copy to ".env.local" in this folder (same directory as package.json), or run `npm install` /
# `npm run ensure:env` — a `.env.local` is created automatically from this file if missing.
# Installed Dropsoft HR (Electron): the API also creates %AppData%\DropsoftHR\.env.local on first run.
# Vite reads VITE_* for the browser; Node reads HR_* when you run `npm run server` or the desktop app.

# --- One PC: local API + browser (SQLite on this machine) ---
HR_API_PORT=32100
VITE_USE_LOCAL_API=true
VITE_LOCAL_API_URL=http://127.0.0.1:32100
# In Dropsoft HR.exe, the UI always uses the API URL from Electron (dynamic port). VITE_LOCAL_API_URL is for browser dev only.

# --- Central server + Electron on every PC (recommended) ---
# SERVER PC: run Dropsoft HR.exe as usual (local SQLite + API), OR `npm run server` with:
#   HR_API_BIND=0.0.0.0
#   HR_API_PORT=32100
#   HR_SERVE_DIST=./dist
# Open Windows Firewall for TCP that port. One process owns hr.db — do not share the file over SMB.
#
# CLIENT PCs (Electron only): point each workstation at the server — no local database.
#   Option A — environment variable: HR_REMOTE_API_URL=http://SERVER_LAN_IP:32100
#   Option B — file: %AppData%\DropsoftHR\remote-api.json  →  { "baseUrl": "http://SERVER_LAN_IP:32100" }
#   Option C — one-time wizard: run:  "Dropsoft HR.exe" --set-server

# Keep HR_API_PORT and VITE_LOCAL_API_URL on the same port when developing on one machine.

# Mobile pairing QR (Settings → Mobile pairing): when VITE_LOCAL_API_URL is 127.0.0.1, set this to your PC's LAN URL
# so the QR is scannable from phones (same Wi-Fi). Example: VITE_PAIRING_LAN_URL=http://192.168.1.50:32100
# VITE_PAIRING_LAN_URL=

# --- Appwrite (web / cloud; no local API) ---
# VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# VITE_APPWRITE_PROJECT_ID=
# VITE_APPWRITE_DATABASE_ID=
# Create collections from appwrite-collections-json.json (or run node appwrite-auto-setup.js).
# School operational expenses need: expense_categories, expense_suppliers, operational_expenses.
