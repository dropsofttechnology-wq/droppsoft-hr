<?xml version="1.0" encoding="utf-8"?>
<!-- Allow HTTP to LAN HR server (not only HTTPS). Tighten domains in production if needed. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
