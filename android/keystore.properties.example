# Copy to keystore.properties (in this folder) and fill in real values.
# Never commit keystore.properties or your .keystore file.
#
# Create a keystore once (example):
#   keytool -genkey -v -keystore dropsoft-release.keystore -alias dropsoft -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=dropsoft-release.keystore
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=dropsoft
keyPassword=YOUR_KEY_PASSWORD
